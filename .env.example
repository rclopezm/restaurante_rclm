# ============================================================
# VARIABLES DE ENTORNO — API Restaurante
# ============================================================

# --- SERVIDOR ---
PORT=3000
NODE_ENV=development

# --- BASE DE DATOS (PostgreSQL) ---
# Cambia estos valores según tu instalación de PostgreSQL
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=tu_contraseña_aqui
DB_NAME=restaurante_db
DB_PORT=5432

# --- JWT (JSON Web Token) ---
# Usa una cadena larga y aleatoria. Puedes generar una con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=24h

# --- PRISMA ---
DATABASE_URL="postgresql://postgres:tu_contraseña_aqui@localhost:5432/restaurante_db"
